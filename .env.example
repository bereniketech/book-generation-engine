# LLM Providers
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# Image Generation
REPLICATE_API_TOKEN=
STABILITY_AI_API_KEY=

# Database & Storage
DATABASE_URL=
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_STORAGE_BUCKET=books

# Message Queue
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
RABBITMQ_MANAGEMENT_URL=http://localhost:15672
MAX_RETRIES=3

# Redis (progress store)
REDIS_URL=redis://localhost:6379

# Email
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=

# App
APP_ENV=development
LOG_LEVEL=INFO
ADMIN_API_KEY=changeme

# LLM Fallback Chain
LLM_FALLBACK_CHAIN=anthropic,openai,gemini
MAX_LLM_RETRIES=2

# Job Recovery
STALE_JOB_TIMEOUT=300

# Batch Processing
MAX_PARALLEL_JOBS=10
BATCH_THROTTLE_DELAY=0.5

# CLI
BOOKGEN_API_URL=http://localhost:8000
